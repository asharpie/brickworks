# Turso (libSQL) connection — get these from https://app.turso.tech
# after you create a database.
#
#   turso db show brickworks --url
#   turso db tokens create brickworks
#
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-long-auth-token-here

# Optional — only used by `npm run dev` locally.
PORT=3000
